{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Gizbox",
	"patterns": [
		{
			"include": "#strings"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.gizbox",
					"match": "\\b(namespace|class|struct|own|bor|typeof|sizeof|enum|import|using|if|else|while|for|return|switch|case|break|default|null|delete|new|this|const|extern|export)\\b"
				},
				{
					"name": "storage.type.primitive.gizbox",
					"match": "\\b(bool|int|uint|long|ulong|float|double|char|string|void)\\b"
				}

			]
		},
		
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.gizbox",
					"match": "//[^\r\n]*"
				}
			]
		},

		"strings": {
			"name": "string.quoted.double.gizbox",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.gizbox",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.gizbox"
}